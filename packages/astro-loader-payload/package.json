{
  "name": "@avovix/astro-loader-payload",
  "version": "0.4.0",
  "description": "Astro content layer loader for PayloadCMS, with build-time and live collections and full typed.",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "withastro",
    "astro-loader",
    "payload",
    "payloadcms",
    "cms",
    "content-layer",
    "loader"
  ],
  "author": {
    "name": "Stephen Covell",
    "email": "stephen@sledgehammer.dev",
    "url": "https://avovix.com"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mock": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avovix/bridge.git",
    "directory": "packages/astro-loader-payload"
  },
  "homepage": "https://github.com/avovix/bridge/tree/main/packages/astro-loader-payload#readme",
  "bugs": "https://github.com/avovix/bridge/issues",
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@payloadcms/sdk": "^3",
    "@vitest/coverage-v8": "4.0.18",
    "astro": "^7",
    "payload": "^3",
    "typescript": "^6.0.3",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "@payloadcms/sdk": "^3",
    "astro": "^7",
    "payload": "^3"
  },
  "peerDependenciesMeta": {
    "@payloadcms/sdk": {
      "optional": true
    }
  }
}
